// ── DATA PERSISTENCE ───────────────────────────────────────────────────────────
function readData() {
  try {
    if (fsSync.existsSync(DATA_FILE))
      return JSON.parse(fsSync.readFileSync(DATA_FILE, 'utf8'));
  } catch(e) { console.error('readData error:', e.message); }
  return { playlist: [], categories: null };
}
function writeData(data) {
  try { fsSync.writeFileSync(DATA_FILE, JSON.stringify(data, null, 2), 'utf8'); return true; }
  catch(e) { console.error('writeData error:', e.message); return false; }
}

app.get('/api/data', (req, res) => res.json(readData()));
app.post('/api/data', (req, res) => {
  const { playlist, categories } = req.body;
  const current = readData();
  writeData({
    playlist:   playlist   !== undefined ? playlist   : current.playlist,
    categories: categories !== undefined ? categories : current.categories,
  });
  res.json({ ok: true });
});

// ── INNERTUBE HELPERS ──────────────────────────────────────────────────────────
function innerTubeRequest(path_, payload, headers, timeoutMs = 8000) {
  return new Promise((resolve, reject) => {
    const body = JSON.stringify(payload);
    const req = https.request({
      hostname: 'www.youtube.com',
      path: path_ + '?prettyPrint=false',
      method: 'POST',
      headers: { 'Content-Type':'application/json','Content-Length':Buffer.byteLength(body), ...headers },
      timeout: timeoutMs,
    }, res => {
      const chunks = [];
      res.on('data', d => chunks.push(d));
      res.on('end', () => { try { resolve(JSON.parse(Buffer.concat(chunks).toString())); } catch(e) { resolve(null); } });
    });
    req.on('timeout', () => { req.destroy(); reject(new Error('InnerTube request timed out')); });
    req.on('error', reject);
    req.write(body); req.end();
  });
}

const WEB_HEADERS = {
  'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 Chrome/124.0.0.0 Safari/537.36',
  'Accept-Language': 'en-US,en;q=0.9',
  'Origin': 'https://www.youtube.com',
  'Referer': 'https://www.youtube.com/'
};
const WEB_CTX = { clientName:'WEB', clientVersion:'2.20240101.00.00', hl:'en', gl:'US' };
const TV_CTX  = { clientName:'TVHTML5', clientVersion:'7.20240101.00.00', hl:'en', gl:'US' };
const TV_HEADERS = { 'User-Agent': 'Mozilla/5.0 (SMART-TV; Linux; Tizen 5.0) AppleWebKit/538.1 Safari/538.1' };

// ── SEARCH ─────────────────────────────────────────────────────────────────────
function extractTracksFromJson(json) {
  const tracks = [], seenIds = new Set();
  let continuationToken = null;
  const contentPaths = [
    json?.contents?.twoColumnSearchResultsRenderer?.primaryContents?.sectionListRenderer?.contents,
    json?.contents?.sectionListRenderer?.contents,
    json?.onResponseReceivedCommands?.[0]?.appendContinuationItemsAction?.continuationItems,
  ].filter(Boolean);
  for (const contents of contentPaths) {
    for (const section of contents) {
      if (section?.continuationItemRenderer) {
        continuationToken = section.continuationItemRenderer?.continuationEndpoint?.continuationCommand?.token || null;
        continue;
      }
      const items = section?.itemSectionRenderer?.contents || section?.musicShelfRenderer?.contents || [];
      for (const item of items) {
        const v = item.videoRenderer || item.compactVideoRenderer;
        if (!v || !v.videoId || seenIds.has(v.videoId)) continue;
        const lengthText = v.lengthText?.simpleText || v.lengthText?.runs?.[0]?.text || '';
        if (lengthText) {
          const parts = lengthText.split(':').map(Number);
          const secs = parts.length===1?parts[0]:parts.length===2?parts[0]*60+parts[1]:parts[0]*3600+parts[1]*60+parts[2];
          if (secs>0 && secs<60) continue;
        }
        seenIds.add(v.videoId);
        tracks.push({ id:v.videoId, title:v.title?.runs?.[0]?.text||v.title?.simpleText||'Unknown', thumbnail:`https://i.ytimg.com/vi/${v.videoId}/mqdefault.jpg` });
      }
    }
    if (tracks.length >= 5) break;
  }
  return { tracks, continuationToken };
}

async function innerTubeSearch(query, continuationToken=null) {
  const musicHints = /audio|lyrics|official|song|mix|remix|feat|ft\b/i;
  const q = (!continuationToken && !musicHints.test(query)) ? query + ' official audio' : query;
  
  const webPayload = continuationToken
    ? { context:{client:WEB_CTX}, continuation:continuationToken }
    : { context:{client:WEB_CTX}, query:q, params:'EgIQAQ==' };
    
  try {
    const json = await innerTubeRequest('/youtubei/v1/search', webPayload, WEB_HEADERS, 3500);
    if (json) {
      const { tracks, continuationToken:next } = extractTracksFromJson(json);
      if (tracks.length > 0) return { tracks:tracks.slice(0,20), continuationToken:next };
    }
  } catch(e) { console.error('[Search] WEB timeout/error - falling back rapidly'); }
  
  const tvPayload = continuationToken
    ? { context:{client:TV_CTX}, continuation:continuationToken }
    : { context:{client:TV_CTX}, query:q };
    
  try {
    const json = await innerTubeRequest('/youtubei/v1/search', tvPayload, TV_HEADERS, 4500);
    if (json) {
      const { tracks, continuationToken:next } = extractTracksFromJson(json);
      return { tracks:tracks.slice(0,20), continuationToken:next };
    }
  } catch(e) { console.error('[Search] TV error:', e.message); }
  
  return { tracks:[], continuationToken:null };
}

app.post('/api/search', async (req, res) => {
  try {
    const { query, continuationToken } = req.body;
    res.json(await innerTubeSearch(query, continuationToken||null));
  } catch(e) { res.json({ tracks:[], continuationToken:null }); }
});

// ── PLAYLIST IMPORT ────────────────────────────────────────────────────────────
function extractPlaylistId(input) {
  input = input.trim();
  if (/^PL[A-Za-z0-9_-]{10,}$/.test(input)) return input;
  try {
    const url = new URL(input);
    return url.searchParams.get('list') || null;
  } catch(e) { return null; }
}

async function fetchPlaylistTracks(playlistId, pageToken=null) {
  const payload = pageToken
    ? { context:{client:WEB_CTX}, continuation:pageToken }
    : { context:{client:WEB_CTX}, browseId:'VL'+playlistId };
  try {
    const json = await innerTubeRequest('/youtubei/v1/browse', payload, WEB_HEADERS, 10000);
    if (!json) return { tracks:[], nextToken:null, title:'Unknown Playlist' };

    const tracks = [];
    const seenIds = new Set();
    let nextToken = null;
    let title = 'YouTube Playlist';

    const header = json?.header?.playlistHeaderRenderer;
    if (header?.title?.simpleText) title = header.title.simpleText;
    if (header?.title?.runs?.[0]?.text) title = header.title.runs[0].text;

    const extractFromContents = (contents) => {
      if (!contents) return;
      for (const item of contents) {
        if (item?.continuationItemRenderer) {
          nextToken = item.continuationItemRenderer?.continuationEndpoint?.continuationCommand?.token || null;
          continue;
        }
        const renderer = item?.playlistVideoRenderer;
        if (!renderer || !renderer.videoId || seenIds.has(renderer.videoId)) continue;
        if (renderer.isPlayable === false) continue;
        seenIds.add(renderer.videoId);
        tracks.push({
          id: renderer.videoId,
          title: renderer.title?.runs?.[0]?.text || renderer.title?.simpleText || 'Unknown',
          thumbnail: `https://i.ytimg.com/vi/${renderer.videoId}/mqdefault.jpg`
        });
      }
    };

    const initContents = json?.contents?.twoColumnBrowseResultsRenderer?.tabs?.[0]?.tabRenderer?.content?.sectionListRenderer?.contents?.[0]?.itemSectionRenderer?.contents?.[0]?.playlistVideoListRenderer?.contents;
    extractFromContents(initContents);
    const contContents = json?.onResponseReceivedActions?.[0]?.appendContinuationItemsAction?.continuationItems;
    extractFromContents(contContents);

    return { tracks, nextToken, title };
  } catch(e) {
    console.error('[Playlist] fetch error:', e.message);
    return { tracks:[], nextToken:null, title:'Unknown Playlist' };
  }
}

app.post('/api/playlist-import', async (req, res) => {
  try {
    const { input } = req.body;
    const playlistId = extractPlaylistId(input);
    if (!playlistId) return res.json({ ok:false, error:'Invalid playlist URL or ID' });

    console.log(`[PlaylistImport] Fetching playlist: ${playlistId}`);
    const allTracks = [];
    let token = null;
    let title = 'YouTube Playlist';
    let pages = 0;

    do {
      const { tracks, nextToken, title:t } = await fetchPlaylistTracks(playlistId, token);
      if (pages === 0) title = t;
      allTracks.push(...tracks);
      token = nextToken;
      pages++;
      if (pages >= 10) break;
    } while (token && allTracks.length < 500);

    console.log(`[PlaylistImport] Got ${allTracks.length} tracks from "${title}"`);
    res.json({ ok:true, tracks:allTracks, title, count:allTracks.length });
  } catch(e) {
    console.error('[PlaylistImport] error:', e.message);
    res.json({ ok:false, error:e.message });
  }
});

// ── DOWNLOAD ENGINE ────────────────────────────────────────────────────────────
const BG_DOWNLOAD_GAP_MS = 8000;
const MAX_BG_CONCURRENT  = 1;
const MAX_DECK_CONCURRENT = 2;

let   bgRunning       = 0;
let   deckRunning     = 0;
let   lastBgFinished  = 0;
const bgQueue         = [];
const deckQueue       = [];
const dlFailed        = new Set();
const activeProcs     = {};

function getLocalFile(videoId) {
  try { 
    const fileName = videoId + '.m4a';
    if (fsSync.existsSync(path.join(DOWNLOAD_FOLDER, fileName))) return fileName;
    return null;
  }
  catch(e) { return null; }
}

async function runDeckDownload(track) {
  const vid = track.id;
  if (getLocalFile(vid)) return;

  if (activeDownloads.has(vid)) {
    console.log(`[DeckDL] Track ${vid} already downloading, will poll for completion`);
    return;
  }

  deckRunning++;
  activeDownloads.add(vid);
  console.log(`[DeckDL] Immediate start: ${vid} "${track.title||''}"`);
  try {
    const out = path.join(DOWNLOAD_FOLDER, vid + '.m4a');
    const proc = spawn('yt-dlp', [
      '--no-check-certificates',
      '-f', 'bestaudio[ext=m4a]',
      '--no-playlist',
      '--no-warnings',
      '-o', out,
      `https://www.youtube.com/watch?v=${vid}`
    ]);
    activeProcs[vid] = proc;
    await new Promise((resolve, reject) => {
      proc.on('close', code => { delete activeProcs[vid]; code === 0 ? resolve() : reject(new Error('exit ' + code)); });
      proc.on('error', err => { delete activeProcs[vid]; reject(err); });
      setTimeout(() => { proc.kill(); reject(new Error('deck dl timeout')); }, 120000);
    });
    console.log(`[DeckDL] Done: ${vid}`);
  } catch(e) {
    console.error(`[DeckDL] Failed: ${vid} — ${e.message}`);
    dlFailed.add(vid);
  } finally {
    activeDownloads.delete(vid);
    deckRunning--;
  }
}

function queueBgDownload(trackData) {
  const vid = trackData.id;
  if (getLocalFile(vid)) return;
  if (dlFailed.has(vid)) return;
  if (activeDownloads.has(vid)) return;
  if (bgQueue.find(q => q.id === vid)) return;
  bgQueue.push(trackData);
  tickBgQueue();
}

async function tickBgQueue() {
  if (bgRunning >= MAX_BG_CONCURRENT) return;
  if (bgQueue.length === 0) return;
  const wait = BG_DOWNLOAD_GAP_MS - (Date.now() - lastBgFinished);
  if (wait > 0) { setTimeout(tickBgQueue, wait); return; }

  const track = bgQueue.shift();
  if (!track) return;
  if (getLocalFile(track.id) || activeDownloads.has(track.id)) { tickBgQueue(); return; }

  bgRunning++;
  activeDownloads.add(track.id);
  console.log(`[BgDL] Start: ${track.id} "${track.title||''}"`);
  try {
    const out = path.join(DOWNLOAD_FOLDER, track.id + '.m4a');
    const proc = spawn('yt-dlp', [
      '--no-check-certificates',
      '-f', 'bestaudio[ext=m4a]',
      '--no-playlist',
      '--sleep-requests', '2',
      '--no-warnings',
      '-o', out,
      `https://www.youtube.com/watch?v=${track.id}`
    ]);
    activeProcs[track.id] = proc;
    await new Promise((resolve, reject) => {
      proc.on('close', code => { delete activeProcs[track.id]; code === 0 ? resolve() : reject(new Error('exit ' + code)); });
      proc.on('error', err => { delete activeProcs[track.id]; reject(err); });
      setTimeout(() => { proc.kill(); reject(new Error('bg dl timeout')); }, 180000);
    });
    console.log(`[BgDL] Done: ${track.id}`);
  } catch(e) {
    console.error(`[BgDL] Failed: ${track.id} — ${e.message}`);
    dlFailed.add(track.id);
  } finally {
    activeDownloads.delete(track.id);
    bgRunning--;
    lastBgFinished = Date.now();
    setTimeout(tickBgQueue, BG_DOWNLOAD_GAP_MS);
  }
}

app.post('/api/download', (req, res) => {
  runDeckDownload(req.body).catch(console.error);
  res.json({ ok: true });
});

app.post('/api/bg-download-queue', (req, res) => {
  const tracks = req.body.tracks || [];
  let queued = 0;
  for (const t of tracks) {
    if (!getLocalFile(t.id) && !dlFailed.has(t.id)) { queueBgDownload(t); queued++; }
  }
  console.log(`[BgQueue] Queued ${queued} tracks`);
  res.json({ ok: true, queued });
});

app.post('/api/dl-status', (req, res) => {
  const ids = req.body.ids || [];
  const downloaded = {};
  
  let existingFiles = new Set();
  try { 
    fsSync.readdirSync(DOWNLOAD_FOLDER).forEach(f => existingFiles.add(f));
  } catch(e) {}
  
  for (const id of ids) {
    downloaded[id] = existingFiles.has(id + '.m4a');
  }
  
  res.json({
    downloaded,
    queueLength: bgQueue.length,
    active: [...activeDownloads],
  });
});

app.post('/api/check', async (req, res) => {
  const vid = req.body.id;
  const local = getLocalFile(vid);
  if (local) {
    const fp = path.join(DOWNLOAD_FOLDER, local);
    const stats = fsSync.statSync(fp);
    
    if (!activeDownloads.has(vid) && stats.size > 10000) {
      return res.json({ ready: true, url: '/stream_local/' + local });
    }

    if (lastKnownSizes[vid] === stats.size && stats.size > 10000)
      return res.json({ ready: true, url: '/stream_local/' + local });
    
    lastKnownSizes[vid] = stats.size;
  }
  res.json({ ready: false });
});

app.get('/stream_local/:filename', (req, res) => {
  const file = path.join(DOWNLOAD_FOLDER, req.params.filename);
  if (!fsSync.existsSync(file)) return res.status(404).send('Not found');
  res.sendFile(file);
});

